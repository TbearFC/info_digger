ANTHROPIC_API_KEY=your_key_here
DB_PATH=./data/info_digger.db
GITHUB_TOKEN=           # optional — raises rate limit from 60 to 5000 req/hr
DB_BACKFILLED=          # set to "1" after first backfill completes (auto-set by app)
CLAUDE_MODEL=claude-haiku-4-5-20251001  # model for summarizer + /api/ask
NITTER_URL=             # Nitter instance URL — nitter.net is offline; supply your own
TWITTER_ENABLED=false   # set to true to enable Twitter/Nitter crawler
TWITTER_ACCOUNTS=karpathy,ylecun,sama   # comma-separated accounts to track
HF_API_TOKEN=           # optional — raises HuggingFace API rate limit
