# Required
ANTHROPIC_API_KEY=your_key_here

# Optional — SQLite path (auto-created)
DB_PATH=./data/info_digger.db

# Optional — model used for summaries and /api/ask
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional — raises GitHub rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

# Optional — raises HuggingFace API rate limit
HF_API_TOKEN=

# Optional — set to 1 to skip the history backfill on restart (auto-set by app)
DB_BACKFILLED=

# Twitter/Nitter crawler (disabled by default)
# nitter.net is offline — you need a self-hosted Nitter instance
TWITTER_ENABLED=false
NITTER_URL=
TWITTER_ACCOUNTS=karpathy,ylecun,sama
